<Window x:Class="DvbSatelliteTv.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVB-S/S2 Satellite TV" Height="760" Width="1180" MinHeight="680" MinWidth="980"
        Background="#F4F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="160" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="DVB-S/S2 Receiver" FontSize="26" FontWeight="SemiBold" Foreground="#17202A" />
                <TextBlock Text="Hotbird 13E, Universal LNB 9750/10600, direct cable, FTA only" Foreground="#52616F" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DetectButton" Content="Detect Device" Width="120" Height="34" Margin="0,0,8,0" Click="DetectButton_Click" />
                <Button x:Name="ScanButton" Content="Scan Hotbird" Width="120" Height="34" Margin="0,0,8,0" Click="ScanButton_Click" />
                <Button x:Name="ParseTsButton" Content="Parse TS" Width="90" Height="34" Margin="0,0,8,0" Click="ParseTsButton_Click" />
                <Button x:Name="RecordTsButton" Content="Record TS" Width="96" Height="34" Margin="0,0,8,0" Click="RecordTsButton_Click" />
                <Button x:Name="CancelScanButton" Content="Cancel" Width="82" Height="34" Margin="0,0,8,0" IsEnabled="False" Click="CancelScanButton_Click" />
                <Button x:Name="ClearButton" Content="Clear" Width="82" Height="34" Margin="0,0,8,0" Click="ClearButton_Click" />
                <Button x:Name="SaveButton" Content="Save Channels" Width="120" Height="34" Click="SaveButton_Click" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,12,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Transponders" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="Frequency MHz" Foreground="#52616F" />
                                <TextBox x:Name="FrequencyBox" Text="10719" Height="28" />
                            </StackPanel>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Symbol rate KS/s" Foreground="#52616F" />
                                <TextBox x:Name="SymbolRateBox" Text="27500" Height="28" />
                            </StackPanel>
                        </UniformGrid>
                        <UniformGrid Columns="4" Margin="0,8,0,0">
                            <StackPanel Margin="0,0,6,0">
                                <TextBlock Text="LNB low" Foreground="#52616F" />
                                <TextBox x:Name="LnbLowBox" Text="9750" Height="28" />
                            </StackPanel>
                            <StackPanel Margin="6,0,6,0">
                                <TextBlock Text="LNB high" Foreground="#52616F" />
                                <TextBox x:Name="LnbHighBox" Text="10600" Height="28" />
                            </StackPanel>
                            <StackPanel Margin="6,0,6,0">
                                <TextBlock Text="Switch" Foreground="#52616F" />
                                <TextBox x:Name="LnbSwitchBox" Text="11700" Height="28" />
                            </StackPanel>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock Text="Capture s" Foreground="#52616F" />
                                <TextBox x:Name="CaptureSecondsBox" Text="8" Height="28" />
                            </StackPanel>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <ComboBox x:Name="PolarizationBox" Width="96" Height="28" SelectedIndex="1" Margin="0,0,8,0">
                                <ComboBoxItem Content="Horizontal" />
                                <ComboBoxItem Content="Vertical" />
                            </ComboBox>
                            <Button Content="Add" Width="72" Height="28" Click="AddTransponderButton_Click" />
                        </StackPanel>
                    </StackPanel>
                    <DataGrid x:Name="TranspondersGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MHz" Binding="{Binding FrequencyMhz}" Width="70" />
                            <DataGridTextColumn Header="SR" Binding="{Binding SymbolRateKsps}" Width="75" />
                            <DataGridTextColumn Header="Pol" Binding="{Binding Polarization}" Width="80" />
                            <DataGridTextColumn Header="Mode" Binding="{Binding Modulation}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="#111820" CornerRadius="6" Padding="14" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Built-in preview placeholder" Foreground="#DDE6ED" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Border Grid.Row="1" Background="#1C2733" BorderBrush="#2D3B49" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <TextBlock Text="Tune Monitor" Foreground="#DDE6ED" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="TuneButton" DockPanel.Dock="Right" Content="Tune" Width="88" Height="28" Click="TuneButton_Click" />
                            </DockPanel>
                            <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,0">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="IF" Foreground="#93A4B1" />
                                    <TextBlock x:Name="TuneIfText" Text="-" Foreground="#DDE6ED" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="22 kHz" Foreground="#93A4B1" />
                                    <TextBlock x:Name="TuneToneText" Text="-" Foreground="#DDE6ED" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="LNB V" Foreground="#93A4B1" />
                                    <TextBlock x:Name="TuneVoltageText" Text="-" Foreground="#DDE6ED" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Stage" Foreground="#93A4B1" />
                                    <TextBlock x:Name="TuneStageText" Text="-" Foreground="#DDE6ED" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </UniformGrid>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="ScanStatusText" Grid.Row="2" Text="Idle" Foreground="#DDE6ED" HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <ProgressBar x:Name="ScanProgressBar" Grid.Row="3" Height="12" Minimum="0" Maximum="100" Value="0" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="6" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="135" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Device" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock x:Name="DeviceStatusText" Grid.Row="1" Text="Not checked" TextWrapping="Wrap" Foreground="#52616F" Margin="0,8,0,10" />
                    <DataGrid x:Name="BdaFiltersGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110" />
                            <DataGridTextColumn Header="Filter" Binding="{Binding FriendlyName}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Grid.Row="3" Text="Channels" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DataGrid x:Name="ChannelsGrid" Grid.Row="4" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Channel" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="MHz" Binding="{Binding FrequencyMhz}" Width="65" />
                            <DataGridCheckBoxColumn Header="FTA" Binding="{Binding IsFreeToAir}" Width="45" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#D8DEE4" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Diagnostics" FontWeight="SemiBold" Margin="0,0,0,6" />
                <ListBox x:Name="LogList" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
